<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- This is the most appropriate target framework for the game's Unity version. -->
    <TargetFramework>netstandard2.1</TargetFramework>
    <!-- This is the GUID of your mod. Example: com.github.YourAccount.BepInExTemplate -->
    <AssemblyName>com.github.tehUsual.HazardSpam</AssemblyName>
    <!-- This is the display name of your mod. Example: BepInEx Template -->
    <AssemblyTitle>HazardSpam</AssemblyTitle>
    <!-- This is the version number of your mod. -->
    <Version>2.0.5</Version>
  </PropertyGroup>


  <ItemGroup>
    <Compile Include="..\..\..\ConsoleTools\src\ConsoleTools\**\*.cs">
      <Link>ConsoleTools\%(RecursiveDir:ConsoleTools\)%(Filename)%(Extension)</Link>
    </Compile>
    <None Remove="..\..\..\ConsoleTools\src\ConsoleTools\**\*.*" />
  </ItemGroup>
  
  <ItemGroup>
    <Compile Include="..\..\..\NetGameState\src\NetGameState\**\*.cs"
             Exclude="..\..\..\NetGameState\src\NetGameState\Plugin.cs">
      <Link>NetGameState\%(RecursiveDir)%(Filename)%(Extension)</Link>
    </Compile>
	<None Remove="..\..\..\NetGameState\src\NetGameState\**\*.*" />
  </ItemGroup>

</Project>
